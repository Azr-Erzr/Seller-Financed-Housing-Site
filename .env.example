# HomeMatch — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.

# ── Supabase ──────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── How to connect Supabase ───────────────────────────────────────────
# 1. Create a free account at supabase.com
# 2. Create a new project
# 3. Copy your Project URL and anon/public key into a .env file here
# 4. In Vercel: Settings → Environment Variables → add both keys
# 5. In src/lib/storage.js: set USE_SUPABASE = true
# 6. Run the SQL in src/lib/supabase-schema.sql to create your tables
